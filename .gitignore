# ====== UNITY PORTFOLIO GITIGNORE ======
# Keep only code on GitHub, everything else local
# This shows your programming skills without asset bloat

# ====== UNITY CACHE & BUILD FOLDERS ======
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ====== IDE & EDITOR (LOCAL ONLY) ======
.vs/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ====== PROJECT SETTINGS & PACKAGES (LOCAL ONLY) ======
# These are machine/environment specific, not portfolio relevant
/Packages/
/ProjectSettings/
*.json

# ====== BUILD OUTPUT & BINARIES ======
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.apk
*.aab
*.unitypackage
*.app
*.exe

# ====== CRASH REPORTS ======
sysinfo.txt
crashlytics-build.properties

# ====== ASSETS (PORTFOLIO MODE) ======

# Ignorar todo el contenido de Assets
/Assets/*

# Permitir la carpeta Scripts
!/Assets/Scripts/

# Permitir todo dentro de Scripts
!/Assets/Scripts/**

# Solo trackear archivos C#
/Assets/Scripts/**
!/Assets/Scripts/**/*.cs

# Ignorar meta files incluso en Scripts
/Assets/Scripts/**/*.meta

# ====== GIT & CONFIG ======
# Keep .gitignore and .gitattributes
# Keep README.md for documentation

